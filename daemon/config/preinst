#!/bin/bash -e

mkdir -p /var/muondetector

if id -u muonuser >/dev/null 2>&1; then
    echo "User already exists"
else
    useradd muonuser -g users -G dialout,i2c,spi,gpio,users -s /usr/sbin/nologin -r -N -M -d /var/muondetector
fi

chown muonuser:users /var/muondetector
chmod g+w /var/muondetector
